---
interface Props {
  variant?: 'light' | 'dark';
  size?: 'sm' | 'md' | 'lg';
}
const { variant = 'dark', size = 'md' } = Astro.props;

// The logo image already contains the "A CUT ABOVE BARBERSHOP" wordmark
// curved around the seal. No accompanying text needed.
const sizes = {
  sm: 36,
  md: 48,
  lg: 72,
};
const dim = sizes[size];

// Two PNG variants live in /public/. Light is white logo for dark backgrounds.
const src = variant === 'light' ? '/logo-256-light.png' : '/logo-256.png';
---
<a
  href="/"
  aria-label="A Cut Above Barber Shop — Home"
  class="inline-flex items-center shrink-0 group"
>
  <img
    src={src}
    alt="A Cut Above Barber Shop"
    width={dim}
    height={dim}
    decoding="async"
    fetchpriority="high"
    class="block transition-transform duration-300 group-hover:scale-105"
    style={`width:${dim}px;height:${dim}px;`}
  />
</a>
