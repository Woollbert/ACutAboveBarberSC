---
interface Props {
  variant?: 'light' | 'dark';
  size?: 'sm' | 'md' | 'lg';
  /** Hide the side text and show only the seal (rare; default false). */
  iconOnly?: boolean;
}
const { variant = 'dark', size = 'md', iconOnly = false } = Astro.props;

const sizes = {
  sm: { dim: 36, text: 'text-base',  caption: 'text-[9px]'  },
  md: { dim: 48, text: 'text-lg',    caption: 'text-[10px]' },
  lg: { dim: 72, text: 'text-2xl',   caption: 'text-[11px]' },
};
const s = sizes[size];

// Two PNG variants live in /public/. Light is white logo for dark backgrounds.
const src = variant === 'light' ? '/logo-256-light.png' : '/logo-256.png';

const inkColor = variant === 'light' ? 'var(--color-cream)' : 'var(--color-ink)';
const captionColor = variant === 'light' ? 'var(--color-gold-soft)' : 'var(--color-gold-deep)';
---
<a
  href="/"
  aria-label="A Cut Above Barber Shop — Home"
  class="inline-flex items-center gap-3 shrink-0 group"
>
  <img
    src={src}
    alt=""
    width={s.dim}
    height={s.dim}
    decoding="async"
    fetchpriority="high"
    class="block transition-transform duration-300 group-hover:scale-105"
    style={`width:${s.dim}px;height:${s.dim}px;`}
  />
  {!iconOnly && (
    <span class={`leading-tight ${s.text}`} style={`color:${inkColor}`}>
      <span class="block font-semibold tracking-wide" style="font-family:var(--font-display);">A Cut Above</span>
      <span class={`block uppercase tracking-[0.22em] ${s.caption}`} style={`color:${captionColor}`}>Barber Shop</span>
    </span>
  )}
</a>
