---
import type { SocialLinks } from '../data/barbers';

interface Props {
  social?: SocialLinks;
  size?: 'sm' | 'md';
  variant?: 'dark' | 'light';
  /** Show platform names next to icons (more accessible). */
  withLabels?: boolean;
}
const { social, size = 'md', variant = 'dark', withLabels = false } = Astro.props;

if (!social || (!social.instagram && !social.tiktok && !social.facebook)) {
  // Render nothing if no links provided.
}

const dim = size === 'sm' ? 18 : 22;
const pad = size === 'sm' ? 'p-2' : 'p-2.5';
const fg = variant === 'light' ? 'var(--color-cream)' : 'var(--color-ink)';
const bg = variant === 'light' ? 'color-mix(in oklab, var(--color-cream) 14%, transparent)' : 'var(--color-cream-soft)';
const border = variant === 'light' ? 'color-mix(in oklab, var(--color-gold) 60%, transparent)' : 'var(--color-line)';
const hover = variant === 'light' ? 'var(--color-gold-soft)' : 'var(--color-gold-deep)';
---
{social && (social.instagram || social.tiktok || social.facebook) && (
  <ul class="flex flex-wrap items-center gap-2" role="list">
    {social.instagram && (
      <li>
        <a
          href={social.instagram}
          target="_blank"
          rel="noopener me"
          aria-label="Instagram"
          class={`inline-flex items-center gap-2 ${pad} rounded-full transition-colors`}
          style={`color:${fg}; background:${bg}; border:1px solid ${border};`}
          onmouseover={`this.style.color='${hover}'`}
          onmouseout={`this.style.color='${fg}'`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          {withLabels && <span class="text-sm font-medium pr-1">Instagram</span>}
        </a>
      </li>
    )}
    {social.tiktok && (
      <li>
        <a
          href={social.tiktok}
          target="_blank"
          rel="noopener me"
          aria-label="TikTok"
          class={`inline-flex items-center gap-2 ${pad} rounded-full transition-colors`}
          style={`color:${fg}; background:${bg}; border:1px solid ${border};`}
          onmouseover={`this.style.color='${hover}'`}
          onmouseout={`this.style.color='${fg}'`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width={dim} height={dim} viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-5.2 1.74 2.89 2.89 0 0 1 2.31-4.64 2.93 2.93 0 0 1 .88.13V9.4a6.84 6.84 0 0 0-1-.05A6.33 6.33 0 0 0 5.8 20.1a6.34 6.34 0 0 0 10.86-4.43V8.05a8.16 8.16 0 0 0 2.93.55v-3.45a4.85 4.85 0 0 1 0-.46Z"/>
          </svg>
          {withLabels && <span class="text-sm font-medium pr-1">TikTok</span>}
        </a>
      </li>
    )}
    {social.facebook && (
      <li>
        <a
          href={social.facebook}
          target="_blank"
          rel="noopener me"
          aria-label="Facebook"
          class={`inline-flex items-center gap-2 ${pad} rounded-full transition-colors`}
          style={`color:${fg}; background:${bg}; border:1px solid ${border};`}
          onmouseover={`this.style.color='${hover}'`}
          onmouseout={`this.style.color='${fg}'`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width={dim} height={dim} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
          </svg>
          {withLabels && <span class="text-sm font-medium pr-1">Facebook</span>}
        </a>
      </li>
    )}
  </ul>
)}
