---
import { site } from '../data/site';
import { copy } from '../data/copy';

interface Props {
  heading?: string;
  subline?: string;
}

const c = copy.global.ctaBand;
const {
  heading = c.defaultHeading,
  subline = c.defaultSubline,
} = Astro.props;
---
<section class="section" style="background: linear-gradient(180deg, var(--color-cream) 0%, var(--color-cream-soft) 100%);">
  <div class="container-narrow">
    <div
      class="rounded-2xl p-8 md:p-12 text-center"
      style="background: var(--color-ink); color: var(--color-cream); box-shadow: var(--shadow-lift);"
    >
      <p class="eyebrow flex items-center justify-center gap-3" style="color: var(--color-gold);">
        <span class="gold-rule"></span>
        {c.eyebrow}
        <span class="gold-rule"></span>
      </p>
      <h2 class="mt-4 text-3xl md:text-4xl font-semibold" style="color: var(--color-cream);">{heading}</h2>
      <p class="mt-3 text-base md:text-lg" style="color: color-mix(in oklab, var(--color-cream) 80%, transparent);">{subline}</p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
        {site.bookingUrl && (
          <a href={site.bookingUrl} target="_blank" rel="noopener" class="btn btn-gold">Book Online</a>
        )}
        <a href={`tel:${site.phoneTel}`} class={site.bookingUrl ? "btn btn-outline" : "btn btn-gold"} style={site.bookingUrl ? "border-color: var(--color-cream); color: var(--color-cream);" : ""}>Call {site.phone}</a>
        <a href={site.smsHref} class="btn btn-outline" style="border-color: var(--color-cream); color: var(--color-cream);">Text to Book</a>
      </div>
    </div>
  </div>
</section>
