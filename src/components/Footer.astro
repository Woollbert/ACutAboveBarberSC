---
import { site, fullAddress, mapsHref } from '../data/site';
import Logo from './Logo.astro';
import SocialLinks from './SocialLinks.astro';
import { copy } from '../data/copy';
const year = new Date().getFullYear();
const social = site.social as { instagram?: string; tiktok?: string; facebook?: string; google?: string };
const f = copy.global.footer;
---
<footer class="mt-24" style="background-color: var(--color-ink); color: var(--color-cream);">
  <div class="container-wide py-16 grid gap-10 md:grid-cols-12">
    <div class="md:col-span-5">
      <Logo variant="light" size="lg" />
      <p class="mt-5 max-w-md text-sm leading-relaxed" style="color: color-mix(in oklab, var(--color-cream) 80%, transparent);">
        {f.brandLine}
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        {site.bookingUrl && (
          <a href={site.bookingUrl} target="_blank" rel="noopener" class="btn btn-gold">Book Online</a>
        )}
        <a href={`tel:${site.phoneTel}`} class={site.bookingUrl ? "btn btn-outline" : "btn btn-gold"} style={site.bookingUrl ? "border-color: var(--color-cream); color: var(--color-cream);" : ""}>Call {site.phone}</a>
        <a href={site.smsHref} class="btn btn-outline" style="border-color: var(--color-cream); color: var(--color-cream);">Text Us</a>
      </div>
    </div>

    <div class="md:col-span-3">
      <h3 class="eyebrow" style="color: var(--color-gold);">{f.visit}</h3>
      <address class="not-italic mt-3 text-sm leading-relaxed" style="color: color-mix(in oklab, var(--color-cream) 85%, transparent);">
        <a href={mapsHref} target="_blank" rel="noopener" class="hover:underline">
          {site.address.street}<br/>
          Suite indicated • {site.address.city}, {site.address.region} {site.address.postal}
        </a>
      </address>
      <p class="mt-3 text-sm">
        <a href={`tel:${site.phoneTel}`} class="hover:underline">{site.phone}</a>
      </p>
    </div>

    <div class="md:col-span-2">
      <h3 class="eyebrow" style="color: var(--color-gold);">{f.hours}</h3>
      <ul class="mt-3 text-sm space-y-1.5" style="color: color-mix(in oklab, var(--color-cream) 85%, transparent);">
        {site.hours.map(h => (
          <li>
            <span class="block font-medium" style="color: var(--color-cream);">{h.day}</span>
            <span>{h.time}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="md:col-span-2">
      <h3 class="eyebrow" style="color: var(--color-gold);">{f.explore}</h3>
      <ul class="mt-3 text-sm space-y-2" style="color: color-mix(in oklab, var(--color-cream) 85%, transparent);">
        {site.navLinks.map(link => (
          <li><a href={link.href} class="hover:underline">{link.label}</a></li>
        ))}
      </ul>

      {(social.instagram || social.tiktok || social.facebook) && (
        <>
          <h3 class="eyebrow mt-7" style="color: var(--color-gold);">{f.follow}</h3>
          <div class="mt-3">
            <SocialLinks social={social} variant="light" size="md" />
          </div>
        </>
      )}
    </div>
  </div>

  <div class="border-t" style="border-color: color-mix(in oklab, var(--color-cream) 12%, transparent);">
    <div class="container-wide py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs" style="color: color-mix(in oklab, var(--color-cream) 65%, transparent);">
      <p>© {year} {site.name}. All rights reserved.</p>
      <p class="flex items-center gap-2">
        <span aria-hidden="true">★</span>
        <span>{f.tagline}</span>
      </p>
    </div>
  </div>
</footer>
