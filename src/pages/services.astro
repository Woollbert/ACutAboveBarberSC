---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaBand from '../components/CtaBand.astro';
import { services, extras, pricingIsPlaceholder } from '../data/services';
import { site } from '../data/site';
---
<BaseLayout
  title="Services"
  description="Full menu of barber and hair services at A Cut Above Barber Shop in San Clemente: military and regulation cuts, straight razor fades and lineups, beard trims and straight razor shaves, gentleman's cuts, women's haircuts, color and highlights, and custom designs."
>
  <PageHeader
    eyebrow="Services & experience"
    title="A full menu, finished with care."
    subtitle="A complete range of barber and hair services for men and women. Every visit includes attention to detail in a clean, comfortable environment."
  />

  <section class="section">
    <div class="container-wide">
      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map(svc => (
          <li class="card p-7 flex flex-col">
            <div class="flex items-start justify-between gap-3">
              <h2 class="text-xl font-semibold leading-tight" style="font-family: var(--font-display);">{svc.name}</h2>
              {svc.priceFrom && (
                <div class="shrink-0 flex flex-col items-end gap-0.5">
                  <span class="text-sm font-semibold whitespace-nowrap px-3 py-1 rounded-full" style="background: var(--color-ink); color: var(--color-cream);">
                    from {svc.priceFrom}
                  </span>
                  {svc.priceNote && (
                    <span class="text-[10px] uppercase tracking-wider" style="color: var(--color-mute);">{svc.priceNote}</span>
                  )}
                </div>
              )}
            </div>
            <p class="mt-3 text-base leading-relaxed flex-1" style="color: var(--color-mute);">{svc.description}</p>
            {svc.features && (
              <ul class="mt-5 flex flex-wrap gap-1.5">
                {svc.features.map(f => (
                  <li class="text-[11px] uppercase tracking-wider px-2.5 py-1 rounded-full" style="background: var(--color-gold-soft); color: var(--color-gold-deep);">{f}</li>
                ))}
              </ul>
            )}
            {svc.addOns && (
              <div class="mt-4 pt-4 border-t" style="border-color: var(--color-line);">
                <p class="text-[10px] uppercase tracking-widest font-semibold" style="color: var(--color-gold-deep);">Add-ons</p>
                <ul class="mt-2 flex flex-wrap gap-x-3 gap-y-1.5 text-xs" style="color: var(--color-ink-soft);">
                  {svc.addOns.map(a => (
                    <li class="font-medium">{a}</li>
                  ))}
                </ul>
              </div>
            )}
          </li>
        ))}
      </ul>

      <p class="mt-10 text-sm text-center max-w-2xl mx-auto" style="color: var(--color-mute);">
        {pricingIsPlaceholder
          ? <>Prices shown are starting points and vary by barber, length, and complexity. Call <a href={`tel:${site.phoneTel}`} class="underline">{site.phone}</a> for an exact quote, or text us a photo of the cut you want and we'll confirm.</>
          : <>Final price varies by barber, length, and complexity. Call <a href={`tel:${site.phoneTel}`} class="underline">{site.phone}</a> for an exact quote, or text us a photo of the cut you want and we'll confirm.</>
        }
      </p>
    </div>
  </section>

  <!-- Included with every visit -->
  <section class="section" style="background: var(--color-cream-soft); border-block: 1px solid var(--color-line);">
    <div class="container-narrow text-center">
      <p class="eyebrow flex items-center justify-center gap-3"><span class="gold-rule"></span> Included with every visit <span class="gold-rule"></span></p>
      <h2 class="mt-3 text-3xl md:text-4xl font-semibold">Little touches. Big difference.</h2>

      <ul class="mt-10 grid sm:grid-cols-2 gap-4 max-w-3xl mx-auto text-left">
        {extras.map(x => (
          <li class="card p-5 flex items-start gap-3">
            <span aria-hidden="true" class="mt-1 inline-block w-2 h-2 rounded-full shrink-0" style="background: var(--color-gold);"></span>
            <span class="text-base">{x}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- How it works -->
  <section class="section">
    <div class="container-narrow">
      <p class="eyebrow flex items-center gap-3"><span class="gold-rule"></span> How it works</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-semibold max-w-2xl">Simple, friendly, no surprises.</h2>

      <ol class="mt-10 grid md:grid-cols-3 gap-4">
        {[
          { n: '01', t: 'Call or text', d: `Reach us at ${site.phone}. Tell us the service you want and your preferred barber.` },
          { n: '02', t: 'Show up sharp', d: 'Walk in or stop by your scheduled time. Grab a complimentary drink and relax.' },
          { n: '03', t: 'Leave refreshed', d: 'Sharp cut, hot-towel finish where it fits, and you\'re out the door confident.' },
        ].map(step => (
          <li class="card p-6">
            <p class="text-3xl font-semibold" style="font-family: var(--font-display); color: var(--color-gold-deep);">{step.n}</p>
            <h3 class="mt-2 text-lg font-semibold" style="font-family: var(--font-sans);">{step.t}</h3>
            <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-mute);">{step.d}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <CtaBand heading="Pick your service. We'll handle the rest." />
</BaseLayout>
