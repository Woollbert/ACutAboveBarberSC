---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaBand from '../components/CtaBand.astro';
import { gallery } from '../data/gallery';
---
<BaseLayout
  title="Gallery"
  description="Recent work from the barbers at A Cut Above Barber Shop in San Clemente. Skin fades, lineups, designs, military cuts, beard work, women's haircuts, and color."
>
  <PageHeader
    eyebrow="Recent work"
    title="Cuts we're proud of."
    subtitle="A look at the variety of work coming out of our chairs — military fades, custom designs, gentleman's cuts, and women's styles."
  />

  <section class="section">
    <div class="container-wide">
      <ul class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {gallery.map((item) => (
          <li class="card overflow-hidden p-0">
            <a href={item.image} target="_blank" rel="noopener" aria-label={item.caption || 'Recent cut'} class="block group">
              <div class="overflow-hidden">
                <img
                  src={item.image}
                  alt={item.caption || 'Recent cut at A Cut Above Barber Shop'}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-72 sm:h-80 object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                />
              </div>
              {item.caption && (
                <p class="px-4 py-3 text-sm leading-snug" style="color: var(--color-ink-soft);">{item.caption}</p>
              )}
            </a>
          </li>
        ))}
      </ul>

      <p class="mt-10 text-sm text-center max-w-2xl mx-auto" style="color: var(--color-mute);">
        See a cut you like? Mention the photo when you call or text — we can match the look on you.
      </p>
    </div>
  </section>

  <CtaBand heading="See a style you like? Let's book it." />
</BaseLayout>
