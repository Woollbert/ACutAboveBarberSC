---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaBand from '../components/CtaBand.astro';
import { gallery } from '../data/gallery';
import { copy } from '../data/copy';

const c = copy.galleryPage;
---
<BaseLayout title="Gallery" description={c.metaDescription}>
  <PageHeader
    eyebrow={c.header.eyebrow}
    title={c.header.title}
    subtitle={c.header.subtitle}
  />

  <section class="section">
    <div class="container-wide">
      <ul class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {gallery.map((item) => (
          <li class="card overflow-hidden p-0">
            <a href={item.image} target="_blank" rel="noopener" aria-label={item.caption || 'Recent cut'} class="block group">
              <div class="overflow-hidden">
                <img
                  src={item.image}
                  alt={item.caption || 'Recent cut at A Cut Above Barber Shop'}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-72 sm:h-80 object-cover transition-transform duration-300 group-hover:scale-[1.03]"
                />
              </div>
              {item.caption && (
                <p class="px-4 py-3 text-sm leading-snug" style="color: var(--color-ink-soft);">{item.caption}</p>
              )}
            </a>
          </li>
        ))}
      </ul>

      <p class="mt-10 text-sm text-center max-w-2xl mx-auto" style="color: var(--color-mute);">
        {c.footerNote}
      </p>
    </div>
  </section>

  <CtaBand heading={c.ctaHeading} />
</BaseLayout>
