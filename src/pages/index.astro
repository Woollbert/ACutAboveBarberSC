---
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaBand from '../components/CtaBand.astro';
import BarberAvatar from '../components/BarberAvatar.astro';
import { site, fullAddress, mapsHref } from '../data/site';
import { services, extras } from '../data/services';
import { barbers } from '../data/barbers';
---
<BaseLayout
  title={site.name}
  description="Veteran-owned barber shop in San Clemente. Precision cuts, military fades, straight razor shaves, gentleman's cuts, women's haircuts, color, and custom designs. Walk-ins welcome at 1006 S. El Camino Real, Suite A."
>
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <!-- decorative background -->
    <div class="absolute inset-0 -z-10" style="background:
      radial-gradient(60% 60% at 80% 0%, color-mix(in oklab, var(--color-gold-soft) 60%, transparent) 0%, transparent 70%),
      radial-gradient(50% 60% at 0% 100%, color-mix(in oklab, var(--color-gold-soft) 35%, transparent) 0%, transparent 70%),
      var(--color-cream);"></div>

    <div class="container-wide pt-14 pb-16 md:pt-24 md:pb-24 grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <p class="eyebrow flex items-center gap-3">
          <span class="gold-rule"></span>
          San Clemente • Est. by veterans
        </p>
        <h1 class="mt-5 text-5xl md:text-6xl lg:text-7xl font-semibold leading-[1.02] tracking-tight">
          Precision cuts.<br/>
          Straight razor shaves.<br/>
          <span style="color: var(--color-gold-deep);">Clean fades done right.</span>
        </h1>
        <p class="mt-6 text-lg md:text-xl max-w-2xl" style="color: var(--color-mute);">
          With over 30 years of experience, A Cut Above Barber Shop specializes in military cuts,
          modern styles, and detailed grooming for men and women, delivered with consistency,
          care, and attention to detail every visit.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-3">
          {site.bookingUrl && (
            <a href={site.bookingUrl} target="_blank" rel="noopener" class="btn btn-gold">Book Online</a>
          )}
          <a href={`tel:${site.phoneTel}`} class={site.bookingUrl ? "btn btn-outline" : "btn btn-primary"}>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {site.phone}
          </a>
          <a href={site.smsHref} class={site.bookingUrl ? "btn btn-outline" : "btn btn-gold"}>Text to Book</a>
          <a href="/services/" class="btn btn-outline">View Services</a>
        </div>

        <ul class="mt-9 grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-2xl">
          {[
            { k: '30+', v: 'Years experience' },
            { k: '5',   v: 'Skilled barbers' },
            { k: 'All', v: 'Branches welcome' },
            { k: '100%', v: 'Walk-ins welcome' },
          ].map(stat => (
            <li class="text-center sm:text-left">
              <div class="text-2xl md:text-3xl font-semibold" style="font-family: var(--font-display); color: var(--color-ink);">{stat.k}</div>
              <div class="text-xs uppercase tracking-widest mt-1" style="color: var(--color-mute);">{stat.v}</div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Decorative card / "business card" feel -->
      <div class="lg:col-span-5">
        <div class="relative mx-auto max-w-md">
          <div
            class="rounded-2xl p-8 md:p-10 relative overflow-hidden"
            style="background: linear-gradient(160deg, var(--color-ink) 0%, #1f1810 100%); color: var(--color-cream); box-shadow: var(--shadow-lift);"
          >
            <!-- gold corner frame, like the business card -->
            <div aria-hidden="true" class="absolute inset-3 rounded-xl pointer-events-none" style="border: 1px solid color-mix(in oklab, var(--color-gold) 80%, transparent); mask-image: linear-gradient(to bottom right, black 0 35%, transparent 35% 65%, black 65% 100%); -webkit-mask-image: linear-gradient(to bottom right, black 0 35%, transparent 35% 65%, black 65% 100%);"></div>

            <div class="relative">
              <div class="flex items-center gap-4">
                <span
                  class="inline-flex items-center justify-center rounded-md"
                  style="width:64px;height:64px;background:var(--color-ink);border:1.5px solid var(--color-gold);box-shadow: inset 0 0 0 4px var(--color-ink), inset 0 0 0 5px var(--color-gold);"
                >
                  <span style="color: var(--color-gold); font-family: var(--font-display); font-weight: 700; font-size: 22px;">ACA</span>
                </span>
                <div>
                  <p class="text-xs uppercase tracking-[0.22em]" style="color: var(--color-gold);">A Cut Above</p>
                  <p class="text-lg" style="font-family: var(--font-display);">Barber Shop</p>
                </div>
              </div>

              <hr class="my-6 border-0 h-px" style="background: color-mix(in oklab, var(--color-gold) 60%, transparent);"/>

              <p class="eyebrow" style="color: var(--color-gold);">The promise</p>
              <p class="mt-2 text-xl leading-snug" style="font-family: var(--font-display); color: var(--color-cream);">
                "Sit back, relax, and leave sharp, confident, and refreshed."
              </p>

              <ul class="mt-6 space-y-2.5 text-sm" style="color: color-mix(in oklab, var(--color-cream) 85%, transparent);">
                {extras.map(x => (
                  <li class="flex items-start gap-2.5">
                    <span aria-hidden="true" style="color: var(--color-gold); margin-top: 4px;">◆</span>
                    <span>{x}</span>
                  </li>
                ))}
              </ul>

              <div class="mt-7 grid grid-cols-2 gap-3 text-xs">
                <div>
                  <p class="uppercase tracking-widest" style="color: var(--color-gold);">Find us</p>
                  <a href={mapsHref} target="_blank" rel="noopener" class="block mt-1 leading-snug hover:underline" style="color: var(--color-cream);">
                    {site.address.street}<br/>
                    {site.address.city}, {site.address.region}
                  </a>
                </div>
                <div>
                  <p class="uppercase tracking-widest" style="color: var(--color-gold);">Call</p>
                  <a href={`tel:${site.phoneTel}`} class="block mt-1 hover:underline" style="color: var(--color-cream);">{site.phone}</a>
                </div>
              </div>
            </div>
          </div>
          <!-- floating gold accent -->
          <div aria-hidden="true" class="absolute -z-10 -bottom-6 -right-6 w-40 h-40 rounded-full blur-2xl" style="background: color-mix(in oklab, var(--color-gold) 50%, transparent);"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="section">
    <div class="container-wide grid md:grid-cols-12 gap-10 items-start">
      <div class="md:col-span-5">
        <p class="eyebrow flex items-center gap-3">
          <span class="gold-rule"></span> What sets us apart
        </p>
        <h2 class="mt-3 text-3xl md:text-4xl font-semibold">A clean, modern shop with three decades of craft.</h2>
        <p class="mt-5 text-lg" style="color: var(--color-mute);">
          We're San Clemente's veteran-owned barber shop. Every cut is delivered with consistency,
          care, and attention to detail in a space designed for you to relax, refresh, and recharge.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href="/about/" class="btn btn-outline">Our Story</a>
          <a href="/barbers/" class="btn btn-primary">Meet the Team</a>
        </div>
      </div>

      <div class="md:col-span-7 grid sm:grid-cols-2 gap-4">
        {[
          { t: 'Veteran-owned', d: 'Owned by a military veteran and surviving spouse, proudly serving service members from every branch and the broader San Clemente community.' },
          { t: 'Precision craft', d: 'Straight razor fades, lineups, beard work, and detailed designs from barbers with decades of combined experience.' },
          { t: 'For everyone', d: 'Men, women, and kids. Military regulation cuts, gentleman\'s classics, modern styles, and color services.' },
          { t: 'Welcoming space', d: 'Complimentary shampoo and drinks. A clean, modern shop where you\'re a guest, not a number.' },
        ].map(item => (
          <article class="card p-6">
            <div class="flex items-center gap-3">
              <span class="inline-block w-2 h-2 rounded-full" style="background: var(--color-gold);"></span>
              <h3 class="text-lg font-semibold" style="font-family: var(--font-sans);">{item.t}</h3>
            </div>
            <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-mute);">{item.d}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section" style="background: var(--color-cream-soft); border-block: 1px solid var(--color-line);">
    <div class="container-wide">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <p class="eyebrow flex items-center gap-3"><span class="gold-rule"></span> Services</p>
          <h2 class="mt-3 text-3xl md:text-4xl font-semibold max-w-2xl">A full menu of barber and hair services.</h2>
        </div>
        <a href="/services/" class="btn btn-outline self-start md:self-auto">See all services →</a>
      </div>

      <ul class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {services.slice(0, 6).map(svc => (
          <li class="card p-6 h-full flex flex-col">
            <div class="flex items-start justify-between gap-3">
              <h3 class="text-lg font-semibold" style="font-family: var(--font-sans);">{svc.name}</h3>
              {svc.priceFrom && (
                <div class="shrink-0 flex flex-col items-end gap-0.5">
                  <span class="text-xs font-semibold whitespace-nowrap px-2.5 py-1 rounded-full" style="background: var(--color-ink); color: var(--color-cream);">
                    from {svc.priceFrom}
                  </span>
                  {svc.priceNote && (
                    <span class="text-[10px] uppercase tracking-wider" style="color: var(--color-mute);">{svc.priceNote}</span>
                  )}
                </div>
              )}
            </div>
            <p class="mt-2 text-sm leading-relaxed flex-1" style="color: var(--color-mute);">{svc.description}</p>
            {svc.features && (
              <ul class="mt-4 flex flex-wrap gap-1.5">
                {svc.features.map(f => (
                  <li class="text-[11px] uppercase tracking-wider px-2 py-1 rounded-full" style="background: var(--color-gold-soft); color: var(--color-gold-deep);">{f}</li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- BARBERS PREVIEW -->
  <section class="section">
    <div class="container-wide">
      <div class="text-center max-w-2xl mx-auto">
        <p class="eyebrow flex items-center justify-center gap-3"><span class="gold-rule"></span> The chairs <span class="gold-rule"></span></p>
        <h2 class="mt-3 text-3xl md:text-4xl font-semibold">Meet your barbers.</h2>
        <p class="mt-4 text-lg" style="color: var(--color-mute);">
          Each barber has their own specialty so you can choose the right fit for your style.
        </p>
      </div>

      <ul class="mt-12 grid sm:grid-cols-2 lg:grid-cols-5 gap-6">
        {barbers.map(b => (
          <li class="card p-6 text-center">
            <div class="flex justify-center"><BarberAvatar name={b.name} photo={b.photo} size="md" /></div>
            <h3 class="mt-4 text-lg font-semibold" style="font-family: var(--font-sans);">{b.name}</h3>
            <p class="text-xs uppercase tracking-widest mt-1" style="color: var(--color-gold-deep);">{b.role} • {b.years}</p>
            <p class="mt-3 text-sm italic" style="color: var(--color-mute); font-family: var(--font-display);">"{b.tagline}"</p>
          </li>
        ))}
      </ul>

      <div class="mt-10 text-center">
        <a href="/barbers/" class="btn btn-primary">Read full bios →</a>
      </div>
    </div>
  </section>

  <!-- VISIT -->
  <section class="section" style="background: var(--color-cream-soft); border-top: 1px solid var(--color-line);">
    <div class="container-wide grid md:grid-cols-2 gap-10 items-center">
      <div>
        <p class="eyebrow flex items-center gap-3"><span class="gold-rule"></span> Find us</p>
        <h2 class="mt-3 text-3xl md:text-4xl font-semibold">Right on El Camino Real in San Clemente.</h2>
        <p class="mt-5 text-lg" style="color: var(--color-mute);">
          Easy to find, easy to park. Walk-ins are welcome, and same-day appointments are
          often available. Call or text to lock in your barber.
        </p>

        <dl class="mt-8 grid sm:grid-cols-2 gap-6">
          <div>
            <dt class="eyebrow">Address</dt>
            <dd class="mt-2 text-base">
              <a href={mapsHref} target="_blank" rel="noopener" class="hover:underline">
                {site.address.street}<br/>
                {site.address.city}, {site.address.region} {site.address.postal}
              </a>
            </dd>
          </div>
          <div>
            <dt class="eyebrow">Phone</dt>
            <dd class="mt-2 text-base"><a href={`tel:${site.phoneTel}`} class="hover:underline">{site.phone}</a></dd>
          </div>
          <div>
            <dt class="eyebrow">Hours</dt>
            <dd class="mt-2 text-sm space-y-1" style="color: var(--color-mute);">
              {site.hours.map(h => (
                <div><span class="font-medium" style="color: var(--color-ink);">{h.day}:</span> {h.time}</div>
              ))}
            </dd>
          </div>
          <div>
            <dt class="eyebrow">On-site</dt>
            <dd class="mt-2 text-sm" style="color: var(--color-mute);">ATM available • Complimentary shampoo & drinks</dd>
          </div>
        </dl>
      </div>

      <div class="rounded-2xl overflow-hidden border" style="border-color: var(--color-line); box-shadow: var(--shadow-soft);">
        <iframe
          title="Map to A Cut Above Barber Shop"
          src={`https://www.google.com/maps?q=${encodeURIComponent(fullAddress)}&output=embed`}
          width="100%"
          height="380"
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          style="border:0; display:block;"
        ></iframe>
      </div>
    </div>
  </section>

  <CtaBand />
</BaseLayout>
