---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CtaBand from '../../components/CtaBand.astro';
import BarberAvatar from '../../components/BarberAvatar.astro';
import SocialLinks from '../../components/SocialLinks.astro';
import { barbers } from '../../data/barbers';
import { site } from '../../data/site';

export async function getStaticPaths() {
  return barbers.map((b) => ({ params: { slug: b.slug }, props: { barber: b } }));
}

const { barber } = Astro.props;
const firstName = barber.name.split(' ')[0];
---
<BaseLayout
  title={`${barber.name} — ${barber.role}`}
  description={`${barber.name}, ${barber.role.toLowerCase()} at A Cut Above Barber Shop in San Clemente. ${barber.years} of experience. Specialties: ${barber.specialties.join(', ')}.`}
>
  <!-- Header -->
  <section class="pt-12 md:pt-20 pb-8 border-b" style="border-color: var(--color-line);">
    <div class="container-narrow">
      <a href="/barbers/" class="eyebrow inline-flex items-center gap-2 hover:underline">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
        All barbers
      </a>

      <div class="mt-6 grid md:grid-cols-12 gap-8 items-start">
        <div class="md:col-span-4 flex flex-col items-center text-center md:items-start md:text-left">
          <BarberAvatar name={barber.name} photo={barber.photo} size="lg" />
          <h1 class="mt-5 text-3xl md:text-4xl font-semibold leading-tight">{barber.name}</h1>
          <p class="mt-1 text-xs uppercase tracking-[0.22em]" style="color: var(--color-gold-deep);">
            {barber.role} • {barber.years}
          </p>
          <p class="mt-4 text-base italic max-w-xs" style="font-family: var(--font-display); color: var(--color-ink-soft);">
            "{barber.tagline}"
          </p>
          {barber.social && (
            <div class="mt-5">
              <SocialLinks social={barber.social} size="md" />
            </div>
          )}
        </div>

        <div class="md:col-span-8">
          <p class="eyebrow">About</p>
          <p class="mt-3 text-lg leading-relaxed" style="color: var(--color-ink-soft);">{barber.bio}</p>

          <div class="mt-6">
            <p class="eyebrow">Specialties</p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {barber.specialties.map((s) => (
                <li class="text-xs uppercase tracking-wider px-3 py-1.5 rounded-full" style="background: var(--color-gold-soft); color: var(--color-gold-deep);">{s}</li>
              ))}
            </ul>
          </div>

          <div class="mt-7 flex flex-wrap gap-3">
            {site.bookingUrl && (
              <a href={site.bookingUrl} target="_blank" rel="noopener" class="btn btn-gold">Book Online</a>
            )}
            <a href={`tel:${site.phoneTel}`} class={site.bookingUrl ? "btn btn-outline" : "btn btn-primary"}>Call to book {firstName}</a>
            <a href={site.smsHref} class="btn btn-outline">Text us</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Portfolio -->
  <section class="section">
    <div class="container-wide">
      <div class="flex items-end justify-between flex-wrap gap-4">
        <div>
          <p class="eyebrow flex items-center gap-3"><span class="gold-rule"></span> {firstName}'s portfolio</p>
          <h2 class="mt-3 text-3xl md:text-4xl font-semibold">Recent work.</h2>
        </div>
        {barber.portfolio && barber.portfolio.length > 0 && (
          <p class="text-sm" style="color: var(--color-mute);">{barber.portfolio.length} {barber.portfolio.length === 1 ? 'cut' : 'cuts'}</p>
        )}
      </div>

      {barber.portfolio && barber.portfolio.length > 0 ? (
        <ul class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {barber.portfolio.map((p) => (
            <li class="card overflow-hidden p-0">
              <a href={p.image} target="_blank" rel="noopener" class="block">
                <img
                  src={p.image}
                  alt={p.caption || `${barber.name} — recent cut`}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-72 object-cover"
                />
                {p.caption && (
                  <p class="px-4 py-3 text-sm" style="color: var(--color-ink-soft);">{p.caption}</p>
                )}
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <div class="mt-10 card p-10 text-center">
          <p class="text-lg" style="color: var(--color-mute);">
            {firstName}'s portfolio is coming soon. In the meantime, see the full shop gallery for examples of our work.
          </p>
          <a href="/gallery/" class="btn btn-outline mt-6">View shop gallery →</a>
        </div>
      )}
    </div>
  </section>

  <CtaBand heading={`Book your cut with ${firstName}.`} />
</BaseLayout>
