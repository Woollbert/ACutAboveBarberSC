---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import CtaBand from '../../components/CtaBand.astro';
import BarberAvatar from '../../components/BarberAvatar.astro';
import SocialLinks from '../../components/SocialLinks.astro';
import { barbers } from '../../data/barbers';
import { site } from '../../data/site';
import { copy } from '../../data/copy';

const c = copy.barbersPage;
---
<BaseLayout title="Meet the Barbers" description={c.metaDescription}>
  <PageHeader
    eyebrow={c.header.eyebrow}
    title={c.header.title}
    subtitle={c.header.subtitle}
  />

  <section class="section">
    <div class="container-narrow space-y-12">
      {barbers.map((b, i) => (
        <article id={b.slug} class="card p-6 md:p-10">
          <div class="grid md:grid-cols-12 gap-8 items-start">
            <div class={`md:col-span-4 flex flex-col items-center text-center ${i % 2 === 1 ? 'md:order-2' : ''}`}>
              <a href={`/barbers/${b.slug}/`} class="block hover:opacity-90 transition-opacity">
                <BarberAvatar name={b.name} photo={b.photo} size="lg" />
              </a>
              <h2 class="mt-5 text-2xl font-semibold" style="font-family: var(--font-display);">
                <a href={`/barbers/${b.slug}/`} class="hover:underline" style="text-decoration-color: var(--color-gold);">{b.name}</a>
              </h2>
              <p class="mt-1 text-xs uppercase tracking-[0.22em]" style="color: var(--color-gold-deep);">
                {b.role} • {b.years}
              </p>
              <p class="mt-4 text-base italic max-w-xs" style="font-family: var(--font-display); color: var(--color-ink-soft);">
                "{b.tagline}"
              </p>
              {b.social && (
                <div class="mt-4">
                  <SocialLinks social={b.social} size="sm" />
                </div>
              )}
            </div>

            <div class={`md:col-span-8 ${i % 2 === 1 ? 'md:order-1' : ''}`}>
              <p class="eyebrow">Bio</p>
              <p class="mt-3 text-lg leading-relaxed" style="color: var(--color-ink-soft);">{b.bio}</p>

              <div class="mt-6">
                <p class="eyebrow">Specialties</p>
                <ul class="mt-3 flex flex-wrap gap-2">
                  {b.specialties.map(s => (
                    <li class="text-xs uppercase tracking-wider px-3 py-1.5 rounded-full" style="background: var(--color-gold-soft); color: var(--color-gold-deep);">{s}</li>
                  ))}
                </ul>
              </div>

              <div class="mt-7 flex flex-wrap gap-3">
                <a href={`/barbers/${b.slug}/`} class="btn btn-primary">
                  See {b.name.split(' ')[0]}'s portfolio →
                </a>
                {site.bookingUrl && (
                  <a href={site.bookingUrl} target="_blank" rel="noopener" class="btn btn-gold">Book Online</a>
                )}
                <a href={`tel:${site.phoneTel}`} class="btn btn-outline">Call to book</a>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section" style="background: var(--color-cream-soft); border-top: 1px solid var(--color-line);">
    <div class="container-narrow text-center">
      <p class="eyebrow flex items-center justify-center gap-3"><span class="gold-rule"></span> {c.dropBy.eyebrow} <span class="gold-rule"></span></p>
      <h2 class="mt-3 text-3xl md:text-4xl font-semibold">{c.dropBy.headingPrefix} <a href={`tel:${site.phoneTel}`} style="color: var(--color-gold-deep);" class="hover:underline">{site.phone}</a> {c.dropBy.headingSuffix}</h2>
      <p class="mt-4 text-lg" style="color: var(--color-mute);">
        {c.dropBy.subtitle}
      </p>
    </div>
  </section>

  <CtaBand heading={c.ctaHeading} />
</BaseLayout>
