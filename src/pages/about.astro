---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import CtaBand from '../components/CtaBand.astro';
import { copy } from '../data/copy';

const c = copy.about;

// Render simple **bold** markdown in copy strings.
function renderBold(text: string): string {
  return text.replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>');
}
---
<BaseLayout title="About" description={c.metaDescription}>
  <PageHeader
    eyebrow={c.header.eyebrow}
    title={c.header.title}
    subtitle={c.header.subtitle}
  />

  <!-- Owner story -->
  <section class="section">
    <div class="container-narrow grid lg:grid-cols-12 gap-10 items-start">
      <aside class="lg:col-span-4 lg:sticky lg:top-24 self-start">
        <div class="card p-6">
          <p class="eyebrow">{c.ownerCard.eyebrow}</p>
          <h2 class="mt-3 text-2xl font-semibold" style="font-family: var(--font-display);">{c.ownerCard.name}</h2>
          <p class="text-sm mt-1" style="color: var(--color-mute);">{c.ownerCard.subtitle}</p>
          <ul class="mt-5 space-y-2 text-sm" style="color: var(--color-mute);">
            {c.ownerCard.bullets.map(b => (
              <li class="flex gap-2"><span aria-hidden="true" style="color: var(--color-gold-deep)">★</span> {b}</li>
            ))}
          </ul>
        </div>
      </aside>

      <div class="lg:col-span-8 prose-content">
        <p class="text-2xl leading-snug" style="font-family: var(--font-display); color: var(--color-ink);">
          "{c.ownerStory.openingQuote}"
        </p>
        <p class="mt-6 text-lg leading-relaxed" style="color: var(--color-ink-soft);">
          {c.ownerStory.paragraph1}
        </p>
        <p class="mt-5 text-lg leading-relaxed" style="color: var(--color-ink-soft);">
          {c.ownerStory.paragraph2}
        </p>
        <p class="mt-5 text-lg leading-relaxed" style="color: var(--color-ink-soft);">
          {c.ownerStory.paragraph3}
        </p>

        <hr class="my-10 border-0 h-px" style="background: var(--color-line);"/>

        <h3 class="text-2xl font-semibold" style="font-family: var(--font-display);">{c.coOwner.heading}</h3>
        <p class="mt-4 text-lg leading-relaxed" style="color: var(--color-ink-soft);" set:html={renderBold(c.coOwner.paragraph1)} />
        <p class="mt-4 text-lg leading-relaxed" style="color: var(--color-ink-soft);" set:html={renderBold(c.coOwner.paragraph2)} />
      </div>
    </div>
  </section>

  <!-- What sets us apart -->
  <section class="section" style="background: var(--color-cream-soft); border-block: 1px solid var(--color-line);">
    <div class="container-narrow">
      <p class="eyebrow flex items-center gap-3"><span class="gold-rule"></span> {c.whatMakesUsDifferent.eyebrow}</p>
      <h2 class="mt-3 text-3xl md:text-4xl font-semibold max-w-3xl">{c.whatMakesUsDifferent.heading}</h2>

      <div class="mt-10 grid md:grid-cols-3 gap-5">
        {c.whatMakesUsDifferent.cards.map(item => (
          <article class="card p-6">
            <h3 class="text-xl font-semibold" style="font-family: var(--font-display);">{item.title}</h3>
            <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-mute);">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CtaBand
    heading={c.ctaHeading}
    subline={c.ctaSubline}
  />
</BaseLayout>
